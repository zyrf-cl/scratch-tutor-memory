# Copy this file to `.env` and fill in your own values.
# `.env` is gitignored — never commit real keys.

# MiMo (Xiaomi) OpenAI-compatible chat endpoint
# Only needed if you want to run langgraph_demo.py / chat_cli.py / demo_agent.py
# with real LLM-generated tutor feedback. demo.py works without these.
MIMO_API_KEY=
MIMO_BASE_URL=https://token-plan-cn.xiaomimimo.com/v1
MIMO_MODEL=mimo-v2.5-pro

# Kimi (Moonshot) OpenAI-compatible endpoint — powers LLM context-overflow
# summarization for the context-management feature. Set MEMORY_MODULE_USE_KIMI=1
# to enable; otherwise the context window falls back to plain truncation.
# MEMORY_MODULE_USE_KIMI=0
KIMI_API_KEY=
KIMI_BASE_URL=https://api.moonshot.cn/v1
KIMI_MODEL=moonshot-v1-8k

# Override SQLite path. Use `:memory:` for ephemeral in-process storage.
# Defaults to ./memory.db
# MEMORY_MODULE_DB=./memory.db

# Embedder backend. `hash` is zero-dependency. Production should use a real model.
# MEMORY_MODULE_EMBEDDER=hash

# Store backend. SQLite is the default. Milvus requires `uv sync --extra milvus`
# and a running Milvus service.
# MEMORY_MODULE_STORE=sqlite
# MEMORY_MODULE_MILVUS_URI=http://localhost:19530
# MEMORY_MODULE_MILVUS_TOKEN=
# MEMORY_MODULE_MILVUS_DB=
# MEMORY_MODULE_MILVUS_PREFIX=memory_module
# MEMORY_MODULE_MILVUS_TIMEOUT=5
# MEMORY_MODULE_MILVUS_CONSISTENCY=Strong
